# --- Database ---
DATABASE_URL=postgresql+psycopg2://medarchive:medarchive@localhost:5432/medarchive

# --- Celery / Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Storage (raw files are never deleted) ---
STORAGE_DIR=./storage

# --- Normalization thresholds ---
MATCH_AUTO_THRESHOLD=0.85       # cosine/fuzzy score >= this => auto-match
MATCH_REVIEW_FLOOR=0.60         # below this => unmatched; between => review queue
USE_EMBEDDINGS=true             # set false to use RapidFuzz only (no torch needed)
EMBEDDING_MODEL=intfloat/multilingual-e5-base   # E5 = query/passage prefixes auto-applied

# --- Validation ---
PRICE_CHANGE_ANOMALY_PCT=50     # |delta| > this percent vs previous version => flag

# --- OCR ---
OCR_LANG=rus+kaz+eng
OCR_DPI=300
PDF_TEXT_MIN_CHARS_PER_PAGE=200 # below => treat page as scan, run OCR

# --- AI provider: "openai" (cloud) or "ollama" (on-premise, no API key needed) ---
LLM_PROVIDER=openai

# OpenAI keys (used when LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
# OPENAI_EMBEDDING_MODEL=text-embedding-3-large
# LLM_MODEL=gpt-4o-mini
# VISION_MODEL=gpt-4o

# Ollama settings (used when LLM_PROVIDER=ollama — run `ollama serve` locally)
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=qwen2.5:7b
# OLLAMA_VISION_MODEL=qwen2.5vl:7b

# Local embeddings (set EMBEDDING_PROVIDER=sentence_transformers to avoid OpenAI)
# EMBEDDING_PROVIDER=sentence_transformers
# EMBEDDING_MODEL=intfloat/multilingual-e5-large

# AWS Step Functions (optional — if set, uploads trigger SFN instead of Celery)
# AWS_REGION=us-east-1
# AWS_SFN_ARN=arn:aws:states:us-east-1:ACCOUNT_ID:stateMachine:medarchive-document-pipeline
